{
  "openapi": "3.0.0",
  "info": {
    "title": "Bearer Auth Test API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.example.com/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "summary": "Get users (inherits bearer)",
        "responses": {
          "200": {
            "description": "List of users"
          }
        }
      }
    },
    "/public": {
      "get": {
        "summary": "Public endpoint",
        "security": [],
        "responses": {
          "200": {
            "description": "Public data"
          }
        }
      }
    },
    "/admin": {
      "post": {
        "summary": "Admin endpoint (uses bearer)",
        "responses": {
          "201": {
            "description": "Admin action"
          }
        }
      }
    }
  }
}
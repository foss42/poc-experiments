{
  "openapi": "3.0.0",
  "info": {
    "title": "AI Language Model API",
    "description": "Advanced artificial intelligence API for natural language processing, text generation, and machine learning tasks",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.openai.com/v1",
      "description": "OpenAI API server"
    }
  ],
  "paths": {
    "/chat/completions": {
      "post": {
        "summary": "Create chat completion",
        "description": "Generate AI responses using GPT models for conversational AI applications",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "messages": {
                    "type": "array"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI generated response"
          }
        }
      }
    },
    "/models": {
      "get": {
        "summary": "List AI models",
        "description": "Get available machine learning models for text processing and generation",
        "responses": {
          "200": {
            "description": "List of available AI models"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
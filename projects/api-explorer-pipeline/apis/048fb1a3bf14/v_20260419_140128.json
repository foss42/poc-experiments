{
  "openapi": "3.0.0",
  "info": {
    "title": "Pet Store API",
    "description": "A simple API for managing pets in a pet store",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://petstore.example.com/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/pets": {
      "get": {
        "summary": "List all pets",
        "description": "Retrieve a list of all pets in the store",
        "responses": {
          "200": {
            "description": "A list of pets"
          }
        }
      },
      "post": {
        "summary": "Create a new pet",
        "description": "Add a new pet to the store",
        "responses": {
          "201": {
            "description": "Pet created successfully"
          }
        }
      }
    },
    "/pets/{petId}": {
      "get": {
        "summary": "Get pet by ID",
        "description": "Retrieve a specific pet by its ID",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pet details"
          },
          "404": {
            "description": "Pet not found"
          }
        }
      },
      "put": {
        "summary": "Update pet",
        "description": "Update an existing pet's information",
        "responses": {
          "200": {
            "description": "Pet updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete pet",
        "responses": {
          "204": {
            "description": "Pet deleted successfully"
          }
        }
      }
    },
    "/pets/search": {
      "get": {
        "summary": "Search pets",
        "description": "Search for pets by name or category",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results"
          }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "List categories",
        "description": "Get all pet categories",
        "responses": {
          "200": {
            "description": "List of categories"
          }
        }
      }
    }
  }
}
# MCP Apps Interactive Viewer — includes Playwright for full 50-test conformance suite

FROM mcr.microsoft.com/playwright:v1.52.0-noble

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

COPY tsconfig.json ./
COPY src/ src/
COPY fixtures/ fixtures/

EXPOSE 8080

CMD ["npx", "tsx", "src/cli.ts", "--transport", "http", "--url", "http://mcp-server:3000/mcp", "--viewer"]

{
  "name": "mcp-conformance",
  "version": "0.3.0",
  "description": "Transport-agnostic conformance testing for MCP servers — supports stdio and Streamable HTTP, with full MCP Apps coverage",
  "type": "module",
  "bin": {
    "mcp-conformance": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "test": "tsx src/cli.ts --server 'tsx fixtures/test-server.ts'",
    "test:http": "tsx src/cli.ts --transport http --url http://localhost:3000/mcp",
    "test:apps": "tsx src/cli.ts --transport http --url http://localhost:3000/mcp --suite mcp-apps"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  }
}

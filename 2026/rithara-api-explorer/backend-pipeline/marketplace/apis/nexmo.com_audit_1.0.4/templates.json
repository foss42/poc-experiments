      "method": "GET",
      "url": "https://api.nexmo.com/beta/audit/events",
      "headers": {
        "Authorization": "Basic{{NEXMO_COM_BASE64_CREDENTIALS}}"
      },
      "query_params": {},
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{NEXMO_PASSWORD}}",
        "{{NEXMO_USERNAME}}",
        "{{NEXMO_COM_BASE64_CREDENTIALS}}"
      ],
      "notes": "Replace {{NEXMO_USERNAME}} with your NEXMO USERNAME. Replace {{NEXMO_PASSWORD}} with your NEXMO PASSWORD."

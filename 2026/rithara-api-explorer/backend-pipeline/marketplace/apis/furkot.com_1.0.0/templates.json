        "{{TRIP_ID}}",
        "{{FURKOT_ACCESS_TOKEN}}",
        "{{FURKOT_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{FURKOT_ACCESS_TOKEN}} with your FURKOT ACCESS TOKEN. Replace {{TRIP_ID}} with a real trip_id."

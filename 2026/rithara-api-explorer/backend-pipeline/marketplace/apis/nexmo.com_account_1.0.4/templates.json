        "{{API_KEY}}",
        "{{SECRET_ID}}",
        "{{NEXMO_COM_BASE64_CREDENTIALS}}"
      ],
      "notes": "Replace {{NEXMO_USERNAME}} with your NEXMO USERNAME. Replace {{NEXMO_PASSWORD}} with your NEXMO PASSWORD. Replace {{SECRET_ID}} with a real secret_id. Replace {{API_KEY}} with a real api_key."

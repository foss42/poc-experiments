      },
      "query_params": {
        "api_key": "",
        "api_secret": ""
      },
      "body": {
        "provider": "email",
        "value": "bob@company.com"
      },
      "sample_response": {},
      "auth_placeholders": [
        "{{NEXMO_PASSWORD}}",
        "{{NEXMO_USERNAME}}",
        "{{NEXMO_COM_BASE64_CREDENTIALS}}"
      ],
      "notes": "Replace {{NEXMO_USERNAME}} with your NEXMO USERNAME. Replace {{NEXMO_PASSWORD}} with your NEXMO PASSWORD."
    },
    {
      "id": "revoke-an-api-secret",
      "name": "Revoke an API Secret",

      "method": "DELETE",
      "url": "https://api.nexmo.com/accounts/{{API_KEY}}/secrets/{{SECRET_ID}}",
      "headers": {
        "Authorization": "Basic{{NEXMO_COM_BASE64_CREDENTIALS}}"
      },
      "query_params": {},
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{NEXMO_PASSWORD}}",

      "description": "Retrieve the current balance of your Vonage API account",
      "method": "GET",
      "url": "https://api.nexmo.com/account/get-balance",
      "headers": {
        "Authorization": "Basic{{NEXMO_COM_BASE64_CREDENTIALS}}"
      },
      "query_params": {
        "api_key": "",
        "api_secret": ""
      },
      "body": null,
      "sample_response": {
        "autoReload": false,
        "value": 10.171275
      },
      "auth_placeholders": [
        "{{NEXMO_PASSWORD}}",
        "{{NEXMO_USERNAME}}",
        "{{NEXMO_COM_BASE64_CREDENTIALS}}"
      ],
      "notes": "Replace {{NEXMO_USERNAME}} with your NEXMO USERNAME. Replace {{NEXMO_PASSWORD}} with your NEXMO PASSWORD."
    },
    {
      "id": "register-an-email-sender",

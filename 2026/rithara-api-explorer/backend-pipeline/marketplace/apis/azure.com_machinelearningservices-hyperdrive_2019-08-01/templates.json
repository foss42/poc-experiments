{
  "api_id": "azure.com:machinelearningservices-hyperdrive:2019-08-01",
  "endpoint_count": 2,
  "endpoints": [
    {
      "id": "create-an-experiment",
      "name": "Create an Experiment.",
      "description": "Create a HyperDrive Experiment.",
      "method": "POST",
      "url": "https://azure.local/hyperdrive/v1.0/{{ARMSCOPE}}/runs",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer{{AZURE_COM_ACCESS_TOKEN}}"
      },
      "query_params": {},
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{AZURE_ACCESS_TOKEN}}",
        "{{ARMSCOPE}}",
        "{{AZURE_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{AZURE_ACCESS_TOKEN}} with your AZURE ACCESS TOKEN. Replace {{ARMSCOPE}} with a real armscope."
    },
    {
      "id": "cancel-an-experiment",
      "name": "Cancel an Experiment.",
      "description": "Cancel a HyperDrive Experiment.",
      "method": "POST",
      "url": "https://azure.local/hyperdrive/v1.0/{{ARMSCOPE}}/runs/{{RUNID}}/cancel",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer{{AZURE_COM_ACCESS_TOKEN}}"
      },
      "query_params": {},
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{AZURE_ACCESS_TOKEN}}",
        "{{ARMSCOPE}}",
        "{{RUNID}}",
        "{{AZURE_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{AZURE_ACCESS_TOKEN}} with your AZURE ACCESS TOKEN. Replace {{RUNID}} with a real runid. Replace {{ARMSCOPE}} with a real armscope."
    }
  ]
}
      },
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{AZURE_ACCESS_TOKEN}}",
        "{{SCOPE}}",
        "{{COMPLIANCENAME}}",
        "{{AZURE_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{AZURE_ACCESS_TOKEN}} with your AZURE ACCESS TOKEN. Replace {{SCOPE}} with a real scope. Replace {{COMPLIANCENAME}} with a real compliancename."

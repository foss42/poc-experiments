        "{{AZURE_ACCESS_TOKEN}}",
        "{{SCOPE}}",
        "{{AZURE_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{AZURE_ACCESS_TOKEN}} with your AZURE ACCESS TOKEN. Replace {{SCOPE}} with a real scope."

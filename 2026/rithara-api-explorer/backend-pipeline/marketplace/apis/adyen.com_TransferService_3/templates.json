{
  "api_id": "adyen.com:TransferService:3",
  "endpoint_count": 3,
  "endpoints": [
    {
      "id": "get-all-transactions",
      "name": "Get all transactions",
      "description": "Returns all transactions related to a balance account with a payment instrument of type **bankAccount**.\n\nThis endpoint supports cursor-based pagination. The response returns the first page of results, and returns links to the next page when applicable. You can use the links to page through the results. The response also returns links to the previous page when applicable.",
      "method": "GET",
      "url": "https://balanceplatform-api-test.adyen.com/btl/v3/transactions",
      "headers": {
        "X-API-Key": "{{ADYEN_COM_API_KEY}}"
      },
      "query_params": {
        "createdSince": "",
        "createdUntil": ""
      },
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{ADYEN_API_KEY}}",
        "{{ADYEN_COM_API_KEY}}"
      ],
      "notes": "Replace {{ADYEN_API_KEY}} with your ADYEN API KEY."
    },
    {
      "id": "get-a-transaction",
      "name": "Get a transaction",
      "description": "Returns a transaction.",
      "method": "GET",
      "url": "https://balanceplatform-api-test.adyen.com/btl/v3/transactions/{{ID}}",
      "headers": {
        "X-API-Key": "{{ADYEN_COM_API_KEY}}"
      },
      "query_params": {},
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{ID}}",
        "{{ADYEN_API_KEY}}",
        "{{ADYEN_COM_API_KEY}}"
      ],
      "notes": "Replace {{ADYEN_API_KEY}} with your ADYEN API KEY. Replace {{ID}} with a real id."
    },
    {
      "id": "transfer-funds",

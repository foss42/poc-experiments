{
  "api_id": "vtex.local:Message-Center-API:1.0.0",
  "endpoint_count": 1,
  "endpoints": [
    {
      "id": "generate-dkim-keys",
      "name": "Generate DKIM keys",
      "description": "Create DKIM keys for sender that was setup in VTEX mail servers",
      "method": "POST",
      "url": "https://vtex.local/api/mail-service/pvt/providers/{{EMAILPROVIDER}}/dkim",
      "headers": {
        "Content-Type": "application/json",
        "X-VTEX-API-AppKey": "{{VTEX_LOCAL_API_KEY}}"
      },
      "query_params": {},
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{VTEX_API_KEY}}",
        "{{EMAILPROVIDER}}",
        "{{VTEX_LOCAL_API_KEY}}"
      ],
      "notes": "Replace {{VTEX_API_KEY}} with your VTEX API KEY. Replace {{EMAILPROVIDER}} with a real emailprovider."
    }
  ]
}
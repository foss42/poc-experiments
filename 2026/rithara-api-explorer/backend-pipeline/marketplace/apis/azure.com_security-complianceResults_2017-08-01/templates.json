        "Authorization": "Bearer{{AZURE_COM_ACCESS_TOKEN}}"
      },
      "query_params": {
        "api-version": ""
      },
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{AZURE_ACCESS_TOKEN}}",
        "{{SCOPE}}",
        "{{AZURE_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{AZURE_ACCESS_TOKEN}} with your AZURE ACCESS TOKEN. Replace {{SCOPE}} with a real scope."

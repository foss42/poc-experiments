      "name": "GET /{resourceId}/providers/Microsoft.Security/complianceResults/{complianceResultName}",
      "description": "Security Compliance Result",
      "method": "GET",
      "url": "https://management.azure.com/{{RESOURCEID}}/providers/Microsoft.Security/complianceResults/{{COMPLIANCERESULTNAME}}",
      "headers": {
        "Authorization": "Bearer{{AZURE_COM_ACCESS_TOKEN}}"
      },
      "query_params": {
        "api-version": ""
      },
      "body": null,
      "sample_response": {},
      "auth_placeholders": [
        "{{AZURE_ACCESS_TOKEN}}",
        "{{COMPLIANCERESULTNAME}}",
        "{{RESOURCEID}}",
        "{{AZURE_COM_ACCESS_TOKEN}}"
      ],
      "notes": "Replace {{AZURE_ACCESS_TOKEN}} with your AZURE ACCESS TOKEN. Replace {{COMPLIANCERESULTNAME}} with a real complianceresultname. Replace {{RESOURCEID}} with a real resourceid."
    },
    {
      "id": "get-scope-providers-microsoft-security-complianceresults",

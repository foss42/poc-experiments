{
  "api_id": "rapidapi.com:dynamicdocs:1.0",
  "endpoint_count": 1,
  "endpoints": [
    {
      "id": "compile-new-document-pdf",
      "name": "Compile New Document PDF",
      "description": "Compile a PDF document from a specific template",
      "method": "POST",
      "url": "https://dynamicdocs.p.rapidapi.com/templates/{{TEMPLATE-TOKEN}}/compile",
      "headers": {
        "Content-Type": "application/json",
        "ADVICEment API Key": "{{RAPIDAPI_COM_API_KEY}}"
      },
      "query_params": {},
      "body": {
        "Example of dynamic data for the simple report template": {
          "value": {
            "amount": "ZAR 100 000",
            "client": {
              "address": "xx Long Street",
              "company": "ABC Company Pty Ltd",
              "firstName": "John",
              "lastName": "Smith",
              "location": "Cape Town, South Africa"
            },
            "consultant": {
              "address": "xx Rivonia Road",
              "company": "XYZ Company Pty Ltd",
              "firstName": "Kobus",
              "lastName": "van der Merwe",
              "location": "Sandton, South Africa"
            },
            "effectiveDate": "1 February 2021",
            "servicesDescription": "perform analysis on the company's clients and identify existing market segments"
          }
        }
      },
      "sample_response": {},
      "auth_placeholders": [
        "{{RAPIDAPI_API_KEY}}",
        "{{TEMPLATE-TOKEN}}",
        "{{RAPIDAPI_COM_API_KEY}}"
      ],
      "notes": "Replace {{RAPIDAPI_API_KEY}} with your RAPIDAPI API KEY. Replace {{TEMPLATE-TOKEN}} with a real template-token."
    }
  ]
}
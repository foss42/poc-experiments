{
  "info": {
    "title": "Swagger Petstore - OpenAPI 3.0",
    "description": "This is a sample Pet Store Server based on the OpenAPI 3.0 specification.",
    "version": "1.0.11"
  },
  "paths": {
    "/pet": {
      "put": {"summary": "Update an existing pet"},
      "post": {"summary": "Add a new pet to the store"}
    },
    "/pet/findByStatus": {
      "get": {"summary": "Finds Pets by status"}
    },
    "/pet/findByTags": {
      "get": {"summary": "Finds Pets by tags"}
    },
    "/pet/{petId}": {
      "get": {"summary": "Find pet by ID"},
      "post": {"summary": "Updates a pet in the store with form data"},
      "delete": {"summary": "Deletes a pet"}
    },
    "/pet/{petId}/uploadFile": {
      "post": {"summary": "Uploads an image for a pet"}
    },
    "/store/inventory": {
      "get": {"summary": "Returns pet inventories by status"}
    },
    "/store/order": {
      "post": {"summary": "Place an order for a pet"}
    },
    "/store/order/{orderId}": {
      "get": {"summary": "Find purchase order by ID"},
      "delete": {"summary": "Delete purchase order by ID"}
    },
    "/user": {
      "post": {"summary": "Create user"}
    },
    "/user/createWithList": {
      "post": {"summary": "Creates list of users with given input array"}
    },
    "/user/login": {
      "get": {"summary": "Logs user into the system"}
    },
    "/user/logout": {
      "get": {"summary": "Logs out current logged in user session"}
    },
    "/user/{username}": {
      "get": {"summary": "Get user by user name"},
      "put": {"summary": "Update user"},
      "delete": {"summary": "Delete user"}
    }
  }
}

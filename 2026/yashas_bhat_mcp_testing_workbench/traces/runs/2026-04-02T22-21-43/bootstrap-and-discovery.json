{
  "initialize": {
    "protocolVersion": "2025-03-26",
    "capabilities": {
      "resources": {
        "listChanged": true
      },
      "tools": {
        "listChanged": true
      }
    },
    "serverInfo": {
      "name": "sample-mcp-apps-chatflow",
      "version": "1.0.0"
    }
  },
  "tools": [
    {
      "name": "select-sales-metric",
      "description": "Tool to select input data for sales report generation and visualization. Interactive UI for selecting region, sales metrics (like revenue, orders, conversion rate, AOV, CLV, and more.) and time periods (monthly/quarterly).",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "execution": {
        "taskSupport": "forbidden"
      },
      "_meta": {
        "ui": {
          "resourceUri": "ui://sample-mcp-apps-chatflow/sales-metric-input-ui",
          "visibility": [
            "model",
            "app"
          ]
        }
      }
    },
    {
      "name": "get-sales-data",
      "description": "Fetch sales report data for given states, metric, period, and year. Returns structured report with summary, period breakdown, and state-level data.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "states": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of state codes (e.g. ['MH','TN','KA'])"
          },
          "metric": {
            "type": "string",
            "description": "Metric key (e.g. 'revenue')"
          },
          "period": {
            "type": "string",
            "enum": [
              "monthly",
              "quarterly"
            ],
            "description": "Period granularity"
          },
          "year": {
            "type": "string",
            "description": "Year for the report"
          }
        },
        "required": [
          "states",
          "metric",
          "period",
          "year"
        ]
      },
      "execution": {
        "taskSupport": "forbidden"
      },
      "_meta": {
        "ui": {
          "resourceUri": "ui://sample-mcp-apps-chatflow/sales-metric-input-ui",
          "visibility": [
            "app"
          ]
        }
      }
    },
    {
      "name": "visualize-sales-data",
      "description": "Visualize sales report data as interactive charts (bar, line, doughnut). Accepts the structured data previously generated by sales_metric_selector. Shows period breakdown, state distribution, and state comparison charts.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "selections": {
            "type": "object",
            "properties": {
              "states": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Array of state codes"
              },
              "metric": {
                "type": "string",
                "description": "Metric key (e.g. 'revenue')"
              },
              "period": {
                "type": "string",
                "enum": [
                  "monthly",
                  "quarterly"
                ],
                "description": "Period granularity"
              },
              "year": {
                "type": "string",
                "description": "Year"
              }
            },
            "required": [
              "states",
              "metric",
              "period",
              "year"
            ],
            "description": "The selections object from sales_metric_selector output"
          },
          "report": {
            "type": "object",
            "properties": {
              "summary": {
                "type": "object",
                "properties": {
                  "total": {
                    "type": "string"
                  },
                  "average": {
                    "type": "string"
                  },
                  "trend": {
                    "type": "string"
                  },
                  "totalRaw": {
                    "type": "number"
                  },
                  "averageRaw": {
                    "type": "number"
                  }
                },
                "required": [
                  "total",
                  "average",
                  "trend",
                  "totalRaw",
                  "averageRaw"
                ]
              },
              "topState": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "percentage": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "code",
                  "value",
                  "percentage"
                ]
              },
              "periods": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "period": {
                      "type": "string"
                    },
                    "total": {
                      "type": "string"
                    },
                    "stateValues": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {
                        "type": "number"
                      }
                    }
                  },
                  "required": [
                    "period",
                    "total",
                    "stateValues"
                  ]
                }
              },
              "states": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "state": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    },
                    "percentage": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "state",
                    "value",
                    "percentage"
                  ]
                }
              },
              "stateNames": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Ordered state names for column headers"
              }
            },
            "required": [
              "summary",
              "topState",
              "periods",
              "states",
              "stateNames"
            ],
            "description": "The report object from sales_metric_selector output"
          }
        },
        "required": [
          "selections",
          "report"
        ]
      },
      "execution": {
        "taskSupport": "forbidden"
      },
      "_meta": {
        "ui": {
          "resourceUri": "ui://sample-mcp-apps-chatflow/sales-visualization",
          "visibility": [
            "model",
            "app"
          ]
        }
      }
    },

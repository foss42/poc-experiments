{
  "openapi": "3.0.0",
  "info": {
    "title": "AI Chat API",
    "description": "Advanced AI language model API for chat completions and natural language processing",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.openai.com/v1"
    }
  ],
  "paths": {
    "/chat/completions": {
      "post": {
        "summary": "Create AI chat completion",
        "description": "Generate AI responses using language models",
        "responses": {
          "200": {
            "description": "AI response generated"
          }
        }
      }
    },
    "/models": {
      "get": {
        "summary": "List AI models",
        "description": "Get available language models",
        "responses": {
          "200": {
            "description": "List of AI models"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}